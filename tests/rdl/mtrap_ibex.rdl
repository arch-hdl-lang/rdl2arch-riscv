        riscv_csr_addr = 0xB89;
        field { sw = rw; hw = r; reset = 0x0;
                riscv_hw_increment_high_of = "mhpmcounter9"; } value[31:0];
    } mhpmcounter9h @ 0x80;

    reg {
        // mhpmevent9 — RO selector; reads 0x40
        // (Ibex hardwires event = 1 << (counter_idx - 3)).
        riscv_csr_addr = 0x329;
        field { sw = r; hw = r; reset = 0x40; } value[31:0];
    } mhpmevent9 @ 0xA8;

    reg {
        // mhpmcounter10 — event counter: instr_ret_compressed (compressed instructions retired).
        riscv_csr_addr = 0xB0A;
        field { sw = rw; hw = r; reset = 0x0;
                riscv_hw_increment_when = "hpm10_inc_en"; } value[31:0];
    } mhpmcounter10 @ 0x5C;

    reg {
        // mhpmcounter10h — high half, links via
        // `riscv_hw_increment_high_of`.
        riscv_csr_addr = 0xB8A;
        field { sw = rw; hw = r; reset = 0x0;
                riscv_hw_increment_high_of = "mhpmcounter10"; } value[31:0];
    } mhpmcounter10h @ 0x84;

    reg {
        // mhpmevent10 — RO selector; reads 0x80
        // (Ibex hardwires event = 1 << (counter_idx - 3)).
        riscv_csr_addr = 0x32A;
        field { sw = r; hw = r; reset = 0x80; } value[31:0];
    } mhpmevent10 @ 0xAC;

    reg {
        // mhpmcounter11 — event counter: mul_wait (cycles waiting for multiply).
        riscv_csr_addr = 0xB0B;
        field { sw = rw; hw = r; reset = 0x0;
                riscv_hw_increment_when = "hpm11_inc_en"; } value[31:0];
    } mhpmcounter11 @ 0x60;

    reg {
        // mhpmcounter11h — high half, links via
        // `riscv_hw_increment_high_of`.
        riscv_csr_addr = 0xB8B;
        field { sw = rw; hw = r; reset = 0x0;
                riscv_hw_increment_high_of = "mhpmcounter11"; } value[31:0];
    } mhpmcounter11h @ 0x88;

    reg {
        // mhpmevent11 — RO selector; reads 0x100
        // (Ibex hardwires event = 1 << (counter_idx - 3)).
        riscv_csr_addr = 0x32B;
        field { sw = r; hw = r; reset = 0x100; } value[31:0];
    } mhpmevent11 @ 0xB0;

    reg {
        // mhpmcounter12 — event counter: div_wait (cycles waiting for divide).
        riscv_csr_addr = 0xB0C;
        field { sw = rw; hw = r; reset = 0x0;
                riscv_hw_increment_when = "hpm12_inc_en"; } value[31:0];
    } mhpmcounter12 @ 0x64;

    reg {
        // mhpmcounter12h — high half, links via
        // `riscv_hw_increment_high_of`.
        riscv_csr_addr = 0xB8C;
        field { sw = rw; hw = r; reset = 0x0;
                riscv_hw_increment_high_of = "mhpmcounter12"; } value[31:0];
    } mhpmcounter12h @ 0x8C;

    reg {
        // mhpmevent12 — RO selector; reads 0x200
        // (Ibex hardwires event = 1 << (counter_idx - 3)).
        riscv_csr_addr = 0x32C;
        field { sw = r; hw = r; reset = 0x200; } value[31:0];
    } mhpmevent12 @ 0xB4;
};
