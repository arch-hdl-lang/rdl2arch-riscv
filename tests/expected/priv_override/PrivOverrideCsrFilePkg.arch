package PrivOverrideCsrFilePkg

  enum PrivOverrideCsrFileAddr
    Mstatus,
    DebugPeek
  end enum PrivOverrideCsrFileAddr

  struct MstatusReg
    v: UInt<32>;
  end struct MstatusReg

  struct DebugPeekReg
    v: UInt<32>;
  end struct DebugPeekReg

  struct PrivOverrideCsrFileHwifIn
    _reserved: UInt<1>;
  end struct PrivOverrideCsrFileHwifIn

  struct PrivOverrideCsrFileHwifOut
    mstatus_v: UInt<32>;
    debug_peek_v: UInt<32>;
  end struct PrivOverrideCsrFileHwifOut

  bus PrivOverrideCsrFileBus
    addr:     out UInt<12>;
    op:       out UInt<2>;
    write_en: out Bool;
    read_en:  out Bool;
    wdata:    out UInt<32>;
    rdata:    in  UInt<32>;
  end bus PrivOverrideCsrFileBus

end package PrivOverrideCsrFilePkg
