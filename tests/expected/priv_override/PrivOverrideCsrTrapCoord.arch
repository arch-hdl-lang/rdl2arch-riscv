use PrivOverrideCsrFilePkg;

module PrivOverrideCsrTrapCoord
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Async, Low>;
  port trap_enter: in Bool;
  port xret_enter: in Bool;
  port hwif_in_live:  in  PrivOverrideCsrFileHwifIn;
  port hwif_in_drive: out PrivOverrideCsrFileHwifIn;

  comb
    hwif_in_drive._reserved = hwif_in_live._reserved;
  end comb
end module PrivOverrideCsrTrapCoord
