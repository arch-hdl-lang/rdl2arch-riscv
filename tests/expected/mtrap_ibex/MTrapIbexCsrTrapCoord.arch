use MTrapIbexCsrFilePkg;

module MTrapIbexCsrTrapCoord
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Async, Low>;
  port trap_enter: in Bool;
  port xret_enter: in Bool;
  port save_mepc_epc: in UInt<32>;
  port save_mcause_cause: in UInt<32>;
  port save_mtval_tval: in UInt<32>;
  port save_mstatus_mpie: in UInt<1>;
  port save_mstatus_mpp: in UInt<2>;
  port restore_mstatus_mie: in UInt<1>;
  port restore_mstatus_mpie: in UInt<1>;
  port restore_mstatus_mpp: in UInt<2>;
  port mirror_mip_msip: in UInt<1>;
  port mirror_mip_mtip: in UInt<1>;
  port mirror_mip_meip: in UInt<1>;
  port mirror_mip_mfip_0: in UInt<1>;
  port hwif_in_live:  in  MTrapIbexCsrFileHwifIn;
  port hwif_in_drive: out MTrapIbexCsrFileHwifIn;

  comb
    hwif_in_drive.mepc_epc = trap_enter ? save_mepc_epc : hwif_in_live.mepc_epc;
    hwif_in_drive.mcause_cause = trap_enter ? save_mcause_cause : hwif_in_live.mcause_cause;
    hwif_in_drive.mtval_tval = trap_enter ? save_mtval_tval : hwif_in_live.mtval_tval;
    hwif_in_drive.mstatus_reserved_2_1 = hwif_in_live.mstatus_reserved_2_1;
    hwif_in_drive.mstatus_mie = xret_enter ? restore_mstatus_mie : hwif_in_live.mstatus_mie;
    hwif_in_drive.mstatus_reserved_6_4 = hwif_in_live.mstatus_reserved_6_4;
    hwif_in_drive.mstatus_mpie = trap_enter ? save_mstatus_mpie : xret_enter ? restore_mstatus_mpie : hwif_in_live.mstatus_mpie;
    hwif_in_drive.mstatus_reserved_10_8 = hwif_in_live.mstatus_reserved_10_8;
    hwif_in_drive.mstatus_mpp = trap_enter ? save_mstatus_mpp : xret_enter ? restore_mstatus_mpp : hwif_in_live.mstatus_mpp;
    hwif_in_drive.mstatus_wpri_hi = hwif_in_live.mstatus_wpri_hi;
    hwif_in_drive.mie_wpri_0_0 = hwif_in_live.mie_wpri_0_0;
    hwif_in_drive.mie_wpri_2_1 = hwif_in_live.mie_wpri_2_1;
    hwif_in_drive.mie_wpri_6_4 = hwif_in_live.mie_wpri_6_4;
    hwif_in_drive.mie_wpri_10_8 = hwif_in_live.mie_wpri_10_8;
    hwif_in_drive.mie_wpri_15_12 = hwif_in_live.mie_wpri_15_12;
    hwif_in_drive.mie_wpri_hi = hwif_in_live.mie_wpri_hi;
    hwif_in_drive.mip_wpri_0_0 = hwif_in_live.mip_wpri_0_0;
    hwif_in_drive.mip_wpri_2_1 = hwif_in_live.mip_wpri_2_1;
    hwif_in_drive.mip_msip = mirror_mip_msip;
    hwif_in_drive.mip_wpri_6_4 = hwif_in_live.mip_wpri_6_4;
    hwif_in_drive.mip_mtip = mirror_mip_mtip;
    hwif_in_drive.mip_wpri_10_8 = hwif_in_live.mip_wpri_10_8;
    hwif_in_drive.mip_meip = mirror_mip_meip;
    hwif_in_drive.mip_wpri_15_12 = hwif_in_live.mip_wpri_15_12;
    hwif_in_drive.mip_mfip_0 = mirror_mip_mfip_0;
    hwif_in_drive.mip_wpri_hi = hwif_in_live.mip_wpri_hi;
    hwif_in_drive.mcountinhibit_reserved_tm = hwif_in_live.mcountinhibit_reserved_tm;
    hwif_in_drive.mcountinhibit_reserved_hi = hwif_in_live.mcountinhibit_reserved_hi;
    hwif_in_drive.dcsr_nmip = hwif_in_live.dcsr_nmip;
    hwif_in_drive.dcsr_mprven = hwif_in_live.dcsr_mprven;
    hwif_in_drive.dcsr_reserved_5 = hwif_in_live.dcsr_reserved_5;
    hwif_in_drive.dcsr_cause = hwif_in_live.dcsr_cause;
    hwif_in_drive.dcsr_stoptime = hwif_in_live.dcsr_stoptime;
    hwif_in_drive.dcsr_stopcount = hwif_in_live.dcsr_stopcount;
    hwif_in_drive.dcsr_stepie = hwif_in_live.dcsr_stepie;
    hwif_in_drive.dcsr_ebreaks = hwif_in_live.dcsr_ebreaks;
    hwif_in_drive.dcsr_reserved_14 = hwif_in_live.dcsr_reserved_14;
    hwif_in_drive.dcsr_ebreakvu = hwif_in_live.dcsr_ebreakvu;
    hwif_in_drive.dcsr_ebreakvs = hwif_in_live.dcsr_ebreakvs;
    hwif_in_drive.dcsr_reserved_27_18 = hwif_in_live.dcsr_reserved_27_18;
  end comb
end module MTrapIbexCsrTrapCoord
