package MTrapIbexCsrFilePkg

  enum MTrapIbexCsrFileAddr
    Mtvec,
    Mepc,
    Mcause,
    Mtval,
    Mscratch,
    Mstatus,
    Mie,
    Mip,
    Mcountinhibit,
    Mcycle,
    Mcycleh,
    Dcsr,
    Dpc,
    Dscratch0,
    Dscratch1
  end enum MTrapIbexCsrFileAddr

  struct MtvecReg
    mode: UInt<2>;
    base: UInt<30>;
  end struct MtvecReg

  struct MepcReg
    epc: UInt<32>;
  end struct MepcReg

  struct McauseReg
    cause: UInt<32>;
  end struct McauseReg

  struct MtvalReg
    tval: UInt<32>;
  end struct MtvalReg

  struct MscratchReg
    value: UInt<32>;
  end struct MscratchReg

  struct MstatusReg
    wpri_lo: UInt<1>;
    reserved_2_1: UInt<2>;
    mie: UInt<1>;
    reserved_6_4: UInt<3>;
    mpie: UInt<1>;
    reserved_10_8: UInt<3>;
    mpp: UInt<2>;
    wpri_hi: UInt<19>;
  end struct MstatusReg

  struct MieReg
    wpri_0_0: UInt<1>;
    wpri_2_1: UInt<2>;
    msie: UInt<1>;
    wpri_6_4: UInt<3>;
    mtie: UInt<1>;
    wpri_10_8: UInt<3>;
    meie: UInt<1>;
    wpri_15_12: UInt<4>;
    mfie_0: UInt<1>;
    wpri_hi: UInt<15>;
  end struct MieReg

  struct MipReg
    wpri_0_0: UInt<1>;
    wpri_2_1: UInt<2>;
    msip: UInt<1>;
    wpri_6_4: UInt<3>;
    mtip: UInt<1>;
    wpri_10_8: UInt<3>;
    meip: UInt<1>;
    wpri_15_12: UInt<4>;
    mfip_0: UInt<1>;
    wpri_hi: UInt<15>;
  end struct MipReg

  struct McountinhibitReg
    cy: UInt<1>;
    reserved_tm: UInt<1>;
    ir: UInt<1>;
    hpm: UInt<10>;
    reserved_hi: UInt<19>;
  end struct McountinhibitReg

  struct McycleReg
    value: UInt<32>;
  end struct McycleReg

  struct McyclehReg
    value: UInt<32>;
  end struct McyclehReg

  struct DcsrReg
    prv: UInt<2>;
    step: UInt<1>;
    nmip: UInt<1>;
    mprven: UInt<1>;
    reserved_5: UInt<1>;
    cause: UInt<3>;
    stoptime: UInt<1>;
    stopcount: UInt<1>;
    stepie: UInt<1>;
    ebreaku: UInt<1>;
    ebreaks: UInt<1>;
    reserved_14: UInt<1>;
    ebreakm: UInt<1>;
    ebreakvu: UInt<1>;
    ebreakvs: UInt<1>;
    reserved_27_18: UInt<10>;
    xdebugver: UInt<4>;
  end struct DcsrReg

  struct DpcReg
    dpc: UInt<32>;
  end struct DpcReg

  struct Dscratch0Reg
    value: UInt<32>;
  end struct Dscratch0Reg

  struct Dscratch1Reg
    value: UInt<32>;
  end struct Dscratch1Reg

  struct MTrapIbexCsrFileHwifIn
    mepc_epc: UInt<32>;
    mcause_cause: UInt<32>;
    mtval_tval: UInt<32>;
    mstatus_reserved_2_1: UInt<2>;
    mstatus_mie: UInt<1>;
    mstatus_reserved_6_4: UInt<3>;
    mstatus_mpie: UInt<1>;
    mstatus_reserved_10_8: UInt<3>;
    mstatus_mpp: UInt<2>;
    mstatus_wpri_hi: UInt<19>;
    mie_wpri_0_0: UInt<1>;
    mie_wpri_2_1: UInt<2>;
    mie_wpri_6_4: UInt<3>;
    mie_wpri_10_8: UInt<3>;
    mie_wpri_15_12: UInt<4>;
    mie_wpri_hi: UInt<15>;
    mip_wpri_0_0: UInt<1>;
    mip_wpri_2_1: UInt<2>;
    mip_msip: UInt<1>;
    mip_wpri_6_4: UInt<3>;
    mip_mtip: UInt<1>;
    mip_wpri_10_8: UInt<3>;
    mip_meip: UInt<1>;
    mip_wpri_15_12: UInt<4>;
    mip_mfip_0: UInt<1>;
    mip_wpri_hi: UInt<15>;
    mcountinhibit_reserved_tm: UInt<1>;
    mcountinhibit_reserved_hi: UInt<19>;
    dcsr_nmip: UInt<1>;
    dcsr_mprven: UInt<1>;
    dcsr_reserved_5: UInt<1>;
    dcsr_cause: UInt<3>;
    dcsr_stoptime: UInt<1>;
    dcsr_stopcount: UInt<1>;
    dcsr_stepie: UInt<1>;
    dcsr_ebreaks: UInt<1>;
    dcsr_reserved_14: UInt<1>;
    dcsr_ebreakvu: UInt<1>;
    dcsr_ebreakvs: UInt<1>;
    dcsr_reserved_27_18: UInt<10>;
  end struct MTrapIbexCsrFileHwifIn

  struct MTrapIbexCsrFileHwifOut
    mtvec_mode: UInt<2>;
    mtvec_base: UInt<30>;
    mtvec_rdata_flat: UInt<32>;
    mepc_epc: UInt<32>;
    mepc_rdata_flat: UInt<32>;
    mcause_cause: UInt<32>;
    mcause_rdata_flat: UInt<32>;
    mtval_tval: UInt<32>;
    mtval_rdata_flat: UInt<32>;
    mscratch_value: UInt<32>;
    mscratch_rdata_flat: UInt<32>;
    mstatus_wpri_lo: UInt<1>;
    mstatus_mie: UInt<1>;
    mstatus_mpie: UInt<1>;
    mstatus_mpp: UInt<2>;
    mstatus_rdata_flat: UInt<32>;
    mie_msie: UInt<1>;
    mie_mtie: UInt<1>;
    mie_meie: UInt<1>;
    mie_mfie_0: UInt<1>;
    mie_rdata_flat: UInt<32>;
    mip_rdata_flat: UInt<32>;
    mcountinhibit_cy: UInt<1>;
    mcountinhibit_ir: UInt<1>;
    mcountinhibit_hpm: UInt<10>;
    mcountinhibit_rdata_flat: UInt<32>;
    mcycle_value: UInt<32>;
    mcycle_rdata_flat: UInt<32>;
    mcycleh_value: UInt<32>;
    mcycleh_rdata_flat: UInt<32>;
    dcsr_prv: UInt<2>;
    dcsr_step: UInt<1>;
    dcsr_ebreaku: UInt<1>;
    dcsr_ebreakm: UInt<1>;
    dcsr_xdebugver: UInt<4>;
    dcsr_rdata_flat: UInt<32>;
    dpc_dpc: UInt<32>;
    dpc_rdata_flat: UInt<32>;
    dscratch0_value: UInt<32>;
    dscratch0_rdata_flat: UInt<32>;
    dscratch1_value: UInt<32>;
    dscratch1_rdata_flat: UInt<32>;
  end struct MTrapIbexCsrFileHwifOut

  bus MTrapIbexCsrFileBus
    handshake cmd: send kind: valid_ready
      addr:  UInt<12>;
      op:    UInt<2>;
      wdata: UInt<32>;
    end handshake cmd

    handshake rsp: receive kind: valid_only
      rdata: UInt<32>;
    end handshake rsp
  end bus MTrapIbexCsrFileBus

end package MTrapIbexCsrFilePkg
