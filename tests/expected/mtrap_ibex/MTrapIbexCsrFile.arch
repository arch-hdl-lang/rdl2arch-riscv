use MTrapIbexCsrFilePkg;

module MTrapIbexCsrFile
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Async, Low>;
  port csr: target MTrapIbexCsrFileBus;
  port granted: in Bool;
  port cycle_en: in Bool;
  port hpm10_inc_en: in Bool;
  port hpm11_inc_en: in Bool;
  port hpm12_inc_en: in Bool;
  port hpm3_inc_en: in Bool;
  port hpm4_inc_en: in Bool;
  port hpm5_inc_en: in Bool;
  port hpm6_inc_en: in Bool;
  port hpm7_inc_en: in Bool;
  port hpm8_inc_en: in Bool;
  port hpm9_inc_en: in Bool;
  port hwif_in:  in MTrapIbexCsrFileHwifIn;
  port hwif_out: out MTrapIbexCsrFileHwifOut;

  default seq on clk rising;

  reg mtvec_r: MtvecReg reset rst => MtvecReg { mode: 0, base: 0 };
  reg mepc_r: MepcReg reset rst => MepcReg { epc: 0 };
  reg mcause_r: McauseReg reset rst => McauseReg { cause: 0 };
  reg mtval_r: MtvalReg reset rst => MtvalReg { tval: 0 };
  reg mscratch_r: MscratchReg reset rst => MscratchReg { value: 0 };
  reg mstatus_r: MstatusReg reset rst => MstatusReg { wpri_lo: 0, reserved_2_1: 0, mie: 0, reserved_6_4: 0, mpie: 0, reserved_10_8: 0, mpp: 0, wpri_hi: 0 };
  reg mie_r: MieReg reset rst => MieReg { wpri_0_0: 0, wpri_2_1: 0, msie: 0, wpri_6_4: 0, mtie: 0, wpri_10_8: 0, meie: 0, wpri_15_12: 0, mfie_0: 0, wpri_hi: 0 };
  reg mip_r: MipReg reset rst => MipReg { wpri_0_0: 0, wpri_2_1: 0, msip: 0, wpri_6_4: 0, mtip: 0, wpri_10_8: 0, meip: 0, wpri_15_12: 0, mfip_0: 0, wpri_hi: 0 };
  reg mcountinhibit_r: McountinhibitReg reset rst => McountinhibitReg { cy: 0, reserved_tm: 0, ir: 0, hpm: 0, reserved_hi: 0 };
  reg mcycle_r: McycleReg reset rst => McycleReg { value: 0 };
  reg mcycleh_r: McyclehReg reset rst => McyclehReg { value: 0 };
  reg dcsr_r: DcsrReg reset rst => DcsrReg { prv: 3, step: 0, nmip: 0, mprven: 0, reserved_5: 0, cause: 0, stoptime: 0, stopcount: 0, stepie: 0, ebreaku: 0, ebreaks: 0, reserved_14: 0, ebreakm: 0, ebreakvu: 0, ebreakvs: 0, reserved_27_18: 0, xdebugver: 4 };
  reg dpc_r: DpcReg reset rst => DpcReg { dpc: 0 };
  reg dscratch0_r: Dscratch0Reg reset rst => Dscratch0Reg { value: 0 };
  reg dscratch1_r: Dscratch1Reg reset rst => Dscratch1Reg { value: 0 };
  reg mhpmcounter3_r: Mhpmcounter3Reg reset rst => Mhpmcounter3Reg { value: 0 };
  reg mhpmcounter4_r: Mhpmcounter4Reg reset rst => Mhpmcounter4Reg { value: 0 };
  reg mhpmcounter5_r: Mhpmcounter5Reg reset rst => Mhpmcounter5Reg { value: 0 };
  reg mhpmcounter6_r: Mhpmcounter6Reg reset rst => Mhpmcounter6Reg { value: 0 };
  reg mhpmcounter7_r: Mhpmcounter7Reg reset rst => Mhpmcounter7Reg { value: 0 };
  reg mhpmcounter8_r: Mhpmcounter8Reg reset rst => Mhpmcounter8Reg { value: 0 };
  reg mhpmcounter9_r: Mhpmcounter9Reg reset rst => Mhpmcounter9Reg { value: 0 };
  reg mhpmcounter10_r: Mhpmcounter10Reg reset rst => Mhpmcounter10Reg { value: 0 };
  reg mhpmcounter11_r: Mhpmcounter11Reg reset rst => Mhpmcounter11Reg { value: 0 };
  reg mhpmcounter12_r: Mhpmcounter12Reg reset rst => Mhpmcounter12Reg { value: 0 };
  reg mhpmcounter3h_r: Mhpmcounter3hReg reset rst => Mhpmcounter3hReg { value: 0 };
  reg mhpmcounter4h_r: Mhpmcounter4hReg reset rst => Mhpmcounter4hReg { value: 0 };
  reg mhpmcounter5h_r: Mhpmcounter5hReg reset rst => Mhpmcounter5hReg { value: 0 };
  reg mhpmcounter6h_r: Mhpmcounter6hReg reset rst => Mhpmcounter6hReg { value: 0 };
  reg mhpmcounter7h_r: Mhpmcounter7hReg reset rst => Mhpmcounter7hReg { value: 0 };
  reg mhpmcounter8h_r: Mhpmcounter8hReg reset rst => Mhpmcounter8hReg { value: 0 };
  reg mhpmcounter9h_r: Mhpmcounter9hReg reset rst => Mhpmcounter9hReg { value: 0 };
  reg mhpmcounter10h_r: Mhpmcounter10hReg reset rst => Mhpmcounter10hReg { value: 0 };
  reg mhpmcounter11h_r: Mhpmcounter11hReg reset rst => Mhpmcounter11hReg { value: 0 };
  reg mhpmcounter12h_r: Mhpmcounter12hReg reset rst => Mhpmcounter12hReg { value: 0 };
  reg mhpmevent3_r: Mhpmevent3Reg reset rst => Mhpmevent3Reg { value: 1 };
  reg mhpmevent4_r: Mhpmevent4Reg reset rst => Mhpmevent4Reg { value: 2 };
  reg mhpmevent5_r: Mhpmevent5Reg reset rst => Mhpmevent5Reg { value: 4 };
  reg mhpmevent6_r: Mhpmevent6Reg reset rst => Mhpmevent6Reg { value: 8 };
  reg mhpmevent7_r: Mhpmevent7Reg reset rst => Mhpmevent7Reg { value: 16 };
  reg mhpmevent8_r: Mhpmevent8Reg reset rst => Mhpmevent8Reg { value: 32 };
  reg mhpmevent9_r: Mhpmevent9Reg reset rst => Mhpmevent9Reg { value: 64 };
  reg mhpmevent10_r: Mhpmevent10Reg reset rst => Mhpmevent10Reg { value: 128 };
  reg mhpmevent11_r: Mhpmevent11Reg reset rst => Mhpmevent11Reg { value: 256 };
  reg mhpmevent12_r: Mhpmevent12Reg reset rst => Mhpmevent12Reg { value: 512 };


  let csr_rdata_mux: UInt<32> = match csr.cmd_addr
    12'h305 => {mtvec_r.base, mtvec_r.mode},
    12'h341 => mepc_r.epc,
    12'h342 => mcause_r.cause,
    12'h343 => mtval_r.tval,
    12'h340 => mscratch_r.value,
    12'h300 => {19'h0, mstatus_r.mpp, 3'h0, mstatus_r.mpie, 3'h0, mstatus_r.mie, 2'h0, false},
    12'h304 => {15'h0, mie_r.mfie_0, 4'h0, mie_r.meie, 3'h0, mie_r.mtie, 3'h0, mie_r.msie, 2'h0, false},
    12'h344 => {15'h0, mip_r.mfip_0, 4'h0, mip_r.meip, 3'h0, mip_r.mtip, 3'h0, mip_r.msip, 2'h0, false},
    12'h320 => {19'h0, mcountinhibit_r.hpm, mcountinhibit_r.ir, false, mcountinhibit_r.cy},
    12'hb00 => mcycle_r.value,
    12'hb80 => mcycleh_r.value,
    12'h7b0 => {dcsr_r.xdebugver, 10'h0, false, false, dcsr_r.ebreakm, false, false, dcsr_r.ebreaku, false, false, false, dcsr_r.cause, false, false, dcsr_r.nmip, dcsr_r.step, dcsr_r.prv},
    12'h7b1 => dpc_r.dpc,
    12'h7b2 => dscratch0_r.value,
    12'h7b3 => dscratch1_r.value,
    12'hb03 => mhpmcounter3_r.value,
    12'hb04 => mhpmcounter4_r.value,
    12'hb05 => mhpmcounter5_r.value,
    12'hb06 => mhpmcounter6_r.value,
    12'hb07 => mhpmcounter7_r.value,
    12'hb08 => mhpmcounter8_r.value,
    12'hb09 => mhpmcounter9_r.value,
    12'hb0a => mhpmcounter10_r.value,
    12'hb0b => mhpmcounter11_r.value,
    12'hb0c => mhpmcounter12_r.value,
    12'hb83 => mhpmcounter3h_r.value,
    12'hb84 => mhpmcounter4h_r.value,
    12'hb85 => mhpmcounter5h_r.value,
    12'hb86 => mhpmcounter6h_r.value,
    12'hb87 => mhpmcounter7h_r.value,
    12'hb88 => mhpmcounter8h_r.value,
    12'hb89 => mhpmcounter9h_r.value,
    12'hb8a => mhpmcounter10h_r.value,
    12'hb8b => mhpmcounter11h_r.value,
    12'hb8c => mhpmcounter12h_r.value,
    12'h323 => mhpmevent3_r.value,
    12'h324 => mhpmevent4_r.value,
    12'h325 => mhpmevent5_r.value,
    12'h326 => mhpmevent6_r.value,
    12'h327 => mhpmevent7_r.value,
    12'h328 => mhpmevent8_r.value,
    12'h329 => mhpmevent9_r.value,
    12'h32a => mhpmevent10_r.value,
    12'h32b => mhpmevent11_r.value,
    12'h32c => mhpmevent12_r.value,
    _ => 0
  end match;

  seq
    mepc_r.epc <= hwif_in.mepc_epc;
    mcause_r.cause <= hwif_in.mcause_cause;
    mtval_r.tval <= hwif_in.mtval_tval;
    mstatus_r.reserved_2_1 <= hwif_in.mstatus_reserved_2_1;
    mstatus_r.mie <= hwif_in.mstatus_mie;
    mstatus_r.reserved_6_4 <= hwif_in.mstatus_reserved_6_4;
    mstatus_r.mpie <= hwif_in.mstatus_mpie;
    mstatus_r.reserved_10_8 <= hwif_in.mstatus_reserved_10_8;
    mstatus_r.mpp <= hwif_in.mstatus_mpp;
    mstatus_r.wpri_hi <= hwif_in.mstatus_wpri_hi;
    mie_r.wpri_0_0 <= hwif_in.mie_wpri_0_0;
    mie_r.wpri_2_1 <= hwif_in.mie_wpri_2_1;
    mie_r.wpri_6_4 <= hwif_in.mie_wpri_6_4;
    mie_r.wpri_10_8 <= hwif_in.mie_wpri_10_8;
    mie_r.wpri_15_12 <= hwif_in.mie_wpri_15_12;
    mie_r.wpri_hi <= hwif_in.mie_wpri_hi;
    mip_r.wpri_0_0 <= hwif_in.mip_wpri_0_0;
    mip_r.wpri_2_1 <= hwif_in.mip_wpri_2_1;
    mip_r.msip <= hwif_in.mip_msip;
    mip_r.wpri_6_4 <= hwif_in.mip_wpri_6_4;
    mip_r.mtip <= hwif_in.mip_mtip;
    mip_r.wpri_10_8 <= hwif_in.mip_wpri_10_8;
    mip_r.meip <= hwif_in.mip_meip;
    mip_r.wpri_15_12 <= hwif_in.mip_wpri_15_12;
    mip_r.mfip_0 <= hwif_in.mip_mfip_0;
    mip_r.wpri_hi <= hwif_in.mip_wpri_hi;
    mcountinhibit_r.reserved_tm <= hwif_in.mcountinhibit_reserved_tm;
    mcountinhibit_r.reserved_hi <= hwif_in.mcountinhibit_reserved_hi;
    dcsr_r.nmip <= hwif_in.dcsr_nmip;
    dcsr_r.mprven <= hwif_in.dcsr_mprven;
    dcsr_r.reserved_5 <= hwif_in.dcsr_reserved_5;
    dcsr_r.cause <= hwif_in.dcsr_cause;
    dcsr_r.stoptime <= hwif_in.dcsr_stoptime;
    dcsr_r.stopcount <= hwif_in.dcsr_stopcount;
    dcsr_r.stepie <= hwif_in.dcsr_stepie;
    dcsr_r.ebreaks <= hwif_in.dcsr_ebreaks;
    dcsr_r.reserved_14 <= hwif_in.dcsr_reserved_14;
    dcsr_r.ebreakvu <= hwif_in.dcsr_ebreakvu;
    dcsr_r.ebreakvs <= hwif_in.dcsr_ebreakvs;
    dcsr_r.reserved_27_18 <= hwif_in.dcsr_reserved_27_18;
    if cycle_en
      mcycle_r.value <= mcycle_r.value +% 1;
    end if
    if cycle_en and (mcycle_r.value == 32'hffffffff)
      mcycleh_r.value <= mcycleh_r.value +% 1;
    end if
    if hpm3_inc_en
      mhpmcounter3_r.value <= mhpmcounter3_r.value +% 1;
    end if
    if hpm4_inc_en
      mhpmcounter4_r.value <= mhpmcounter4_r.value +% 1;
    end if
    if hpm5_inc_en
      mhpmcounter5_r.value <= mhpmcounter5_r.value +% 1;
    end if
    if hpm6_inc_en
      mhpmcounter6_r.value <= mhpmcounter6_r.value +% 1;
    end if
    if hpm7_inc_en
      mhpmcounter7_r.value <= mhpmcounter7_r.value +% 1;
    end if
    if hpm8_inc_en
      mhpmcounter8_r.value <= mhpmcounter8_r.value +% 1;
    end if
    if hpm9_inc_en
      mhpmcounter9_r.value <= mhpmcounter9_r.value +% 1;
    end if
    if hpm10_inc_en
      mhpmcounter10_r.value <= mhpmcounter10_r.value +% 1;
    end if
    if hpm11_inc_en
      mhpmcounter11_r.value <= mhpmcounter11_r.value +% 1;
    end if
    if hpm12_inc_en
      mhpmcounter12_r.value <= mhpmcounter12_r.value +% 1;
    end if
    if hpm3_inc_en and (mhpmcounter3_r.value == 32'hffffffff)
      mhpmcounter3h_r.value <= mhpmcounter3h_r.value +% 1;
    end if
    if hpm4_inc_en and (mhpmcounter4_r.value == 32'hffffffff)
      mhpmcounter4h_r.value <= mhpmcounter4h_r.value +% 1;
    end if
    if hpm5_inc_en and (mhpmcounter5_r.value == 32'hffffffff)
      mhpmcounter5h_r.value <= mhpmcounter5h_r.value +% 1;
    end if
    if hpm6_inc_en and (mhpmcounter6_r.value == 32'hffffffff)
      mhpmcounter6h_r.value <= mhpmcounter6h_r.value +% 1;
    end if
    if hpm7_inc_en and (mhpmcounter7_r.value == 32'hffffffff)
      mhpmcounter7h_r.value <= mhpmcounter7h_r.value +% 1;
    end if
    if hpm8_inc_en and (mhpmcounter8_r.value == 32'hffffffff)
      mhpmcounter8h_r.value <= mhpmcounter8h_r.value +% 1;
    end if
    if hpm9_inc_en and (mhpmcounter9_r.value == 32'hffffffff)
      mhpmcounter9h_r.value <= mhpmcounter9h_r.value +% 1;
    end if
    if hpm10_inc_en and (mhpmcounter10_r.value == 32'hffffffff)
      mhpmcounter10h_r.value <= mhpmcounter10h_r.value +% 1;
    end if
    if hpm11_inc_en and (mhpmcounter11_r.value == 32'hffffffff)
      mhpmcounter11h_r.value <= mhpmcounter11h_r.value +% 1;
    end if
    if hpm12_inc_en and (mhpmcounter12_r.value == 32'hffffffff)
      mhpmcounter12h_r.value <= mhpmcounter12h_r.value +% 1;
    end if
    if csr.cmd_valid
      if granted and (csr.cmd_op != 2'b00)
        if csr.cmd_addr == 12'h305
          mtvec_r.mode <= match (match csr.cmd_op
              2'b01 => csr.cmd_wdata[1:0],
              2'b10 => mtvec_r.mode | csr.cmd_wdata[1:0],
              2'b11 => mtvec_r.mode & (~csr.cmd_wdata[1:0]),
              _    => mtvec_r.mode
            end match)
              2'h0 => 2'h0,
              2'h1 => 2'h1,
              _    => 2'h0
            end match;
          mtvec_r.base <= match csr.cmd_op
              2'b01 => csr.cmd_wdata[31:2],
              2'b10 => mtvec_r.base | csr.cmd_wdata[31:2],
              2'b11 => mtvec_r.base & (~csr.cmd_wdata[31:2]),
              _    => mtvec_r.base
            end match;
        end if
        if csr.cmd_addr == 12'h341
          mepc_r.epc <= (match csr.cmd_op
              2'b01 => csr.cmd_wdata[31:0],
              2'b10 => mepc_r.epc | csr.cmd_wdata[31:0],
              2'b11 => mepc_r.epc & (~csr.cmd_wdata[31:0]),
              _    => mepc_r.epc
            end match) & 32'hfffffffe;
        end if
        if csr.cmd_addr == 12'h342
          mcause_r.cause <= match csr.cmd_op
              2'b01 => csr.cmd_wdata[31:0],
              2'b10 => mcause_r.cause | csr.cmd_wdata[31:0],
              2'b11 => mcause_r.cause & (~csr.cmd_wdata[31:0]),
              _    => mcause_r.cause
            end match;
        end if
        if csr.cmd_addr == 12'h343
          mtval_r.tval <= match csr.cmd_op
              2'b01 => csr.cmd_wdata[31:0],
              2'b10 => mtval_r.tval | csr.cmd_wdata[31:0],
              2'b11 => mtval_r.tval & (~csr.cmd_wdata[31:0]),
              _    => mtval_r.tval
            end match;
        end if
        if csr.cmd_addr == 12'h340
          mscratch_r.value <= match csr.cmd_op
              2'b01 => csr.cmd_wdata[31:0],
              2'b10 => mscratch_r.value | csr.cmd_wdata[31:0],
              2'b11 => mscratch_r.value & (~csr.cmd_wdata[31:0]),
              _    => mscratch_r.value
            end match;
        end if
        if csr.cmd_addr == 12'h300
          mstatus_r.mie <= match csr.cmd_op
              2'b01 => csr.cmd_wdata[3],
              2'b10 => mstatus_r.mie | csr.cmd_wdata[3],
              2'b11 => mstatus_r.mie & (~csr.cmd_wdata[3]),
              _    => mstatus_r.mie
            end match;
          mstatus_r.mpie <= match csr.cmd_op
              2'b01 => csr.cmd_wdata[7],
              2'b10 => mstatus_r.mpie | csr.cmd_wdata[7],
              2'b11 => mstatus_r.mpie & (~csr.cmd_wdata[7]),
              _    => mstatus_r.mpie
            end match;
          mstatus_r.mpp <= (match csr.cmd_op
              2'b01 => csr.cmd_wdata[12:11],
              2'b10 => mstatus_r.mpp | csr.cmd_wdata[12:11],
              2'b11 => mstatus_r.mpp & (~csr.cmd_wdata[12:11]),
              _    => mstatus_r.mpp
            end match) & 2'h3;
        end if
        if csr.cmd_addr == 12'h304
          mie_r.msie <= match csr.cmd_op
              2'b01 => csr.cmd_wdata[3],
              2'b10 => mie_r.msie | csr.cmd_wdata[3],
              2'b11 => mie_r.msie & (~csr.cmd_wdata[3]),
              _    => mie_r.msie
            end match;
          mie_r.mtie <= match csr.cmd_op
              2'b01 => csr.cmd_wdata[7],
              2'b10 => mie_r.mtie | csr.cmd_wdata[7],
              2'b11 => mie_r.mtie & (~csr.cmd_wdata[7]),
              _    => mie_r.mtie
            end match;
          mie_r.meie <= match csr.cmd_op
              2'b01 => csr.cmd_wdata[11],
              2'b10 => mie_r.meie | csr.cmd_wdata[11],
              2'b11 => mie_r.meie & (~csr.cmd_wdata[11]),
              _    => mie_r.meie
            end match;
          mie_r.mfie_0 <= match csr.cmd_op
              2'b01 => csr.cmd_wdata[16],
              2'b10 => mie_r.mfie_0 | csr.cmd_wdata[16],
              2'b11 => mie_r.mfie_0 & (~csr.cmd_wdata[16]),
              _    => mie_r.mfie_0
            end match;
        end if
        if csr.cmd_addr == 12'h320
          mcountinhibit_r.cy <= match csr.cmd_op
              2'b01 => csr.cmd_wdata[0],
              2'b10 => mcountinhibit_r.cy | csr.cmd_wdata[0],
              2'b11 => mcountinhibit_r.cy & (~csr.cmd_wdata[0]),
              _    => mcountinhibit_r.cy
            end match;
          mcountinhibit_r.ir <= match csr.cmd_op
              2'b01 => csr.cmd_wdata[2],
              2'b10 => mcountinhibit_r.ir | csr.cmd_wdata[2],
              2'b11 => mcountinhibit_r.ir & (~csr.cmd_wdata[2]),
              _    => mcountinhibit_r.ir
            end match;
          mcountinhibit_r.hpm <= match csr.cmd_op
              2'b01 => csr.cmd_wdata[12:3],
              2'b10 => mcountinhibit_r.hpm | csr.cmd_wdata[12:3],
              2'b11 => mcountinhibit_r.hpm & (~csr.cmd_wdata[12:3]),
              _    => mcountinhibit_r.hpm
            end match;
        end if
        if csr.cmd_addr == 12'hb00
          mcycle_r.value <= match csr.cmd_op
              2'b01 => csr.cmd_wdata[31:0],
              2'b10 => mcycle_r.value | csr.cmd_wdata[31:0],
              2'b11 => mcycle_r.value & (~csr.cmd_wdata[31:0]),
              _    => mcycle_r.value
            end match;
        end if
        if csr.cmd_addr == 12'hb80
          mcycleh_r.value <= match csr.cmd_op
              2'b01 => csr.cmd_wdata[31:0],
              2'b10 => mcycleh_r.value | csr.cmd_wdata[31:0],
              2'b11 => mcycleh_r.value & (~csr.cmd_wdata[31:0]),
              _    => mcycleh_r.value
            end match;
        end if
        if csr.cmd_addr == 12'h7b0
          dcsr_r.prv <= match (match csr.cmd_op
              2'b01 => csr.cmd_wdata[1:0],
              2'b10 => dcsr_r.prv | csr.cmd_wdata[1:0],
              2'b11 => dcsr_r.prv & (~csr.cmd_wdata[1:0]),
              _    => dcsr_r.prv
            end match)
              2'h0 => 2'h0,
              2'h3 => 2'h3,
              _    => 2'h0
            end match;
          dcsr_r.step <= match csr.cmd_op
              2'b01 => csr.cmd_wdata[2],
              2'b10 => dcsr_r.step | csr.cmd_wdata[2],
              2'b11 => dcsr_r.step & (~csr.cmd_wdata[2]),
              _    => dcsr_r.step
            end match;
          dcsr_r.ebreaku <= match csr.cmd_op
              2'b01 => csr.cmd_wdata[12],
              2'b10 => dcsr_r.ebreaku | csr.cmd_wdata[12],
              2'b11 => dcsr_r.ebreaku & (~csr.cmd_wdata[12]),
              _    => dcsr_r.ebreaku
            end match;
          dcsr_r.ebreakm <= match csr.cmd_op
              2'b01 => csr.cmd_wdata[15],
              2'b10 => dcsr_r.ebreakm | csr.cmd_wdata[15],
              2'b11 => dcsr_r.ebreakm & (~csr.cmd_wdata[15]),
              _    => dcsr_r.ebreakm
            end match;
        end if
        if csr.cmd_addr == 12'h7b1
          dpc_r.dpc <= (match csr.cmd_op
              2'b01 => csr.cmd_wdata[31:0],
              2'b10 => dpc_r.dpc | csr.cmd_wdata[31:0],
