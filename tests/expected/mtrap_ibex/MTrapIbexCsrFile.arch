use MTrapIbexCsrFilePkg;

module MTrapIbexCsrFile
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;
  port csr: target MTrapIbexCsrFileBus;
  port granted: in Bool;
  port hwif_in:  in MTrapIbexCsrFileHwifIn;
  port hwif_out: out MTrapIbexCsrFileHwifOut;

  default seq on clk rising;

  reg mscratch_r: MscratchReg reset rst => MscratchReg { value: 0 };
  reg mtvec_r: MtvecReg reset rst => MtvecReg { mode: 0, base: 0 };


  let csr_rdata_mux: UInt<32> = match csr.cmd_addr
    12'h340 => mscratch_r.value,
    12'h305 => {mtvec_r.base, mtvec_r.mode},
    _ => 0
  end match;

  seq
    if csr.cmd_valid
      if granted and (csr.cmd_op != 2'b00)
        if csr.cmd_addr == 12'h340
          mscratch_r.value <= match csr.cmd_op
              2'b01 => csr.cmd_wdata[31:0],
              2'b10 => mscratch_r.value | csr.cmd_wdata[31:0],
              2'b11 => mscratch_r.value & (~csr.cmd_wdata[31:0]),
              _    => mscratch_r.value
            end match;
        end if
        if csr.cmd_addr == 12'h305
          mtvec_r.mode <= match (match csr.cmd_op
              2'b01 => csr.cmd_wdata[1:0],
              2'b10 => mtvec_r.mode | csr.cmd_wdata[1:0],
              2'b11 => mtvec_r.mode & (~csr.cmd_wdata[1:0]),
              _    => mtvec_r.mode
            end match)
              2'h0 => 2'h0,
              2'h1 => 2'h1,
              _    => 2'h0
            end match;
          mtvec_r.base <= match csr.cmd_op
              2'b01 => csr.cmd_wdata[31:2],
              2'b10 => mtvec_r.base | csr.cmd_wdata[31:2],
              2'b11 => mtvec_r.base & (~csr.cmd_wdata[31:2]),
              _    => mtvec_r.base
            end match;
        end if
      end if
    end if
  end seq

  comb
    csr.cmd_ready = true;
    csr.rsp_valid = csr.cmd_valid;
    csr.rsp_rdata = csr.cmd_valid ? csr_rdata_mux : 0;
    hwif_out.mscratch_value = mscratch_r.value;
    hwif_out.mtvec_mode = mtvec_r.mode;
    hwif_out.mtvec_base = mtvec_r.base;
  end comb

end module MTrapIbexCsrFile
