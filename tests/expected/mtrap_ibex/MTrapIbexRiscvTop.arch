use MTrapIbexCsrFilePkg;

module MTrapIbexRiscvTop
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Async, Low>;

  port csr_cmd_valid: in  Bool;
  port csr_cmd_ready: out Bool;
  port csr_cmd_addr:  in  UInt<12>;
  port csr_cmd_wdata: in  UInt<32>;
  port csr_rsp_valid: out Bool;
  port csr_rsp_rdata: out UInt<32>;
  port csr_opcode: in  UInt<3>;
  port cur_priv:   in  UInt<2>;
  port trap_enter: in  Bool;
  port xret_enter: in  Bool;
  port save_mepc_epc: in UInt<32>;
  port save_mcause_cause: in UInt<32>;
  port save_mtval_tval: in UInt<32>;
  port save_mstatus_mpie: in UInt<1>;
  port save_mstatus_mpp: in UInt<2>;
  port restore_mstatus_mie: in UInt<1>;
  port restore_mstatus_mpie: in UInt<1>;
  port restore_mstatus_mpp: in UInt<2>;
  port mirror_mip_msip: in UInt<1>;
  port mirror_mip_mtip: in UInt<1>;
  port mirror_mip_meip: in UInt<1>;
  port mirror_mip_mfip_0: in UInt<1>;

  port granted:    out Bool;
  port illegal:    out Bool;
  port cause:      out UInt<5>;

  wire granted_w: Bool;
  wire illegal_w: Bool;
  wire cause_w:   UInt<5>;
  wire cmd_ready_w: Bool;
  wire cmd_op_w:   UInt<2>;
  wire rsp_valid_w: Bool;
  wire rsp_rdata_w: UInt<32>;
  wire hwif_live_w:  MTrapIbexCsrFileHwifIn;
  wire hwif_drive_w: MTrapIbexCsrFileHwifIn;
  wire hwif_out_w:   MTrapIbexCsrFileHwifOut;

  comb
    hwif_live_w.mepc_epc = 0;
    hwif_live_w.mcause_cause = 0;
    hwif_live_w.mtval_tval = 0;
    hwif_live_w.mstatus_reserved_2_1 = 0;
    hwif_live_w.mstatus_mie = 0;
    hwif_live_w.mstatus_reserved_6_4 = 0;
    hwif_live_w.mstatus_mpie = 0;
    hwif_live_w.mstatus_reserved_10_8 = 0;
    hwif_live_w.mstatus_mpp = 0;
    hwif_live_w.mstatus_wpri_hi = 0;
    hwif_live_w.mie_wpri_0_0 = 0;
    hwif_live_w.mie_wpri_2_1 = 0;
    hwif_live_w.mie_wpri_6_4 = 0;
    hwif_live_w.mie_wpri_10_8 = 0;
    hwif_live_w.mie_wpri_15_12 = 0;
    hwif_live_w.mie_wpri_hi = 0;
    hwif_live_w.mip_wpri_0_0 = 0;
    hwif_live_w.mip_wpri_2_1 = 0;
    hwif_live_w.mip_msip = 0;
    hwif_live_w.mip_wpri_6_4 = 0;
    hwif_live_w.mip_mtip = 0;
    hwif_live_w.mip_wpri_10_8 = 0;
    hwif_live_w.mip_meip = 0;
    hwif_live_w.mip_wpri_15_12 = 0;
    hwif_live_w.mip_mfip_0 = 0;
    hwif_live_w.mip_wpri_hi = 0;
    hwif_live_w.mcountinhibit_reserved_tm = 0;
    hwif_live_w.mcountinhibit_reserved_hi = 0;
    hwif_live_w.dcsr_nmip = 0;
    hwif_live_w.dcsr_mprven = 0;
    hwif_live_w.dcsr_reserved_5 = 0;
    hwif_live_w.dcsr_cause = 0;
    hwif_live_w.dcsr_stoptime = 0;
    hwif_live_w.dcsr_stopcount = 0;
    hwif_live_w.dcsr_stepie = 0;
    hwif_live_w.dcsr_ebreaks = 0;
    hwif_live_w.dcsr_reserved_14 = 0;
    hwif_live_w.dcsr_ebreakvu = 0;
    hwif_live_w.dcsr_ebreakvs = 0;
    hwif_live_w.dcsr_reserved_27_18 = 0;

    cmd_op_w = csr_opcode[1:0];
    csr_cmd_ready = cmd_ready_w;
    csr_rsp_valid = rsp_valid_w;
    csr_rsp_rdata = rsp_rdata_w;
    granted = granted_w;
    illegal = illegal_w;
    cause   = cause_w;
  end comb

  inst access: MTrapIbexCsrAccess
    csr_addr   <- csr_cmd_addr;
    csr_opcode <- csr_opcode;
    cur_priv   <- cur_priv;
    valid      <- csr_cmd_valid;
    granted    -> granted_w;
    illegal    -> illegal_w;
    cause      -> cause_w;
  end inst access

  inst trap: MTrapIbexCsrTrapCoord
    clk <- clk; rst <- rst;
    trap_enter <- trap_enter;
    xret_enter <- xret_enter;
    save_mepc_epc <- save_mepc_epc;
    save_mcause_cause <- save_mcause_cause;
    save_mtval_tval <- save_mtval_tval;
    save_mstatus_mpie <- save_mstatus_mpie;
    save_mstatus_mpp <- save_mstatus_mpp;
    restore_mstatus_mie <- restore_mstatus_mie;
    restore_mstatus_mpie <- restore_mstatus_mpie;
    restore_mstatus_mpp <- restore_mstatus_mpp;
    mirror_mip_msip <- mirror_mip_msip;
    mirror_mip_mtip <- mirror_mip_mtip;
    mirror_mip_meip <- mirror_mip_meip;
    mirror_mip_mfip_0 <- mirror_mip_mfip_0;
    hwif_in_live  <- hwif_live_w;
    hwif_in_drive -> hwif_drive_w;
  end inst trap

  inst csr: MTrapIbexCsrFile
    clk <- clk; rst <- rst;
    csr.cmd_valid <- csr_cmd_valid;
    csr.cmd_ready -> cmd_ready_w;
    csr.cmd_addr  <- csr_cmd_addr;
    csr.cmd_op    <- cmd_op_w;
    csr.cmd_wdata <- csr_cmd_wdata;
    csr.rsp_valid -> rsp_valid_w;
    csr.rsp_rdata -> rsp_rdata_w;
    granted <- granted_w;
    hwif_in  <- hwif_drive_w;
    hwif_out -> hwif_out_w;
  end inst csr

end module MTrapIbexRiscvTop
